# ============================================================
# COMO ATIVAR O MODO NUVEM (Google Sheets + Google Drive)
# ============================================================
# 1) Renomeie este arquivo para "secrets.toml" (tire o .example)
# 2) Preencha apenas os 2 IDs abaixo
# 3) A CHAVE da conta de servico e lida do arquivo "service_account.json"
#    que ja esta na raiz do projeto -- voce NAO precisa cola-la aqui.
# ------------------------------------------------------------
# Sem este arquivo (ou sem os IDs), o app roda em MODO LOCAL.

[google]
# ID da PLANILHA Google Sheets (da URL: .../spreadsheets/d/ESTE_ID/edit)
sheet_id = "COLE_O_ID_DA_PLANILHA"
# ID da PASTA do Google Drive onde as fotos serao salvas (da URL: .../folders/ESTE_ID)
drive_folder_id = "COLE_O_ID_DA_PASTA"

# Emails que terao perfil de ADMIN.
[auth]
admin_emails = ["seu-email@exemplo.com"]

# Chave da API do DeepSeek (pagina "Refeicao IA").
[deepseek]
api_key = "COLE_SUA_CHAVE_DEEPSEEK"


# ============================================================
# (OPCIONAL) Para PUBLICAR online no Streamlit Cloud, onde nao
# da para subir o service_account.json, descomente o bloco abaixo
# e cole os campos do JSON. No uso LOCAL, deixe comentado.
# ============================================================
# [gcp_service_account]
# type = "service_account"
# project_id = "..."
# private_key_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "...@....iam.gserviceaccount.com"
# client_id = "..."
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "..."
